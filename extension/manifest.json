{
  "manifest_version": 3,
  "name": "Revise",
  "version": "1.2.1",
  "description": "Track what you learn and get spaced repetition reminders for revision.",
  "permissions": ["activeTab", "storage", "alarms", "tabs"],
  "host_permissions": ["https://revise.mrinal.dev/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://revise.mrinal.dev/*"],
      "js": ["capture-tokens.js"],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://leetcode.com/*",
        "https://*.leetcode.com/*",
        "https://codechef.com/*",
        "https://*.codechef.com/*",
        "https://hackerrank.com/*",
        "https://*.hackerrank.com/*",
        "https://codeforces.com/*",
        "https://*.codeforces.com/*",
        "https://geeksforgeeks.org/*",
        "https://*.geeksforgeeks.org/*",
        "https://interviewbit.com/*",
        "https://*.interviewbit.com/*",
        "https://atcoder.jp/*",
        "https://*.atcoder.jp/*",
        "https://neetcode.io/*",
        "https://*.neetcode.io/*",
        "https://algo.monster/*",
        "https://*.algo.monster/*",
        "https://algomonster.com/*",
        "https://*.algomonster.com/*",
        "https://designgurus.io/*",
        "https://*.designgurus.io/*"
      ],
      "js": ["overlay.js"],
      "run_at": "document_idle"
    }
  ],
  "commands": {
    "toggle-overlay": {
      "suggested_key": {
        "default": "Alt+Shift+R",
        "mac": "MacCtrl+Shift+R"
      },
      "description": "Toggle Revise notes overlay"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
